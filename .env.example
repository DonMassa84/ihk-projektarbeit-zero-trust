# ========================
# Zero-Trust Platform Config
# ========================
APP_NAME="Zero-Trust RBAC Platform"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# ========================
# Database
# ========================
DATABASE_URL=postgresql+asyncpg://zt_user:change-me@localhost:5432/zerotrust
DB_PASSWORD=change-me

# ========================
# Security
# ========================
SECRET_KEY=generate-a-strong-key-with-openssl-rand-64-hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================
# Azure AD / OIDC
# ========================
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
OIDC_ISSUER_URL=

# ========================
# GitHub Integration
# ========================
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# ========================
# Redis
# ========================
REDIS_URL=redis://localhost:6379/0

# ========================
# Hugging Face ML
# ========================
HF_TOKEN=hf_your_token_here
ML_ANOMALY_MODEL_PATH=DonMassa84/zero-trust-anomaly-detector
ML_POLICY_MODEL_PATH=DonMassa84/zero-trust-policy-generator
ML_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ========================
# Monitoring
# ========================
GRAFANA_URL=http://localhost:3001
GRAFANA_PASSWORD=admin